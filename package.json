    "eslint-plugin-prettier": "^5.2.5",
    "jest": "^30.2.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.5.3",
    "puppeteer": "^24.15.0",
    "typescript": "^5.8.2"
  },
